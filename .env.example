# Copy to .env.local for local dev (never commit .env.local).
# These EXPO_PUBLIC_* values are baked into the app bundle at build time.

# Shared secret for the HMAC-TOTP token (must match the Lambda's HMAC_SECRET)
EXPO_PUBLIC_HMAC_SECRET=your-hmac-secret-here

# Lambda Function URL base (SAM deploy output: LambdaFunctionUrl)
EXPO_PUBLIC_LAMBDA_URL=https://xxxxxxxxxxxxxxxx.lambda-url.ap-southeast-2.on.aws

# S3 audio base URL (SAM deploy output: AudioBaseUrl)
EXPO_PUBLIC_AUDIO_BASE_URL=https://your-bucket-name.s3.amazonaws.com
